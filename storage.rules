rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Private document uploads: only authenticated users may write.
    // Read access is intentionally absent here — previews are served through
    // short-lived signed URLs generated by the Cloud Function, which bypass
    // these rules and do not expose a long-lived public token.
    match /uploads/{allPaths=**} {
      allow write: if request.auth != null;
      // Direct reads require auth; preview must use the signed-URL callable.
      allow read: if request.auth != null;
    }

    // Workspace-scoped general assets (e.g. feed images, sources).
    match /workspaces/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Platform-managed workspace files (WorkspaceFilesSection uploads).
    match /workspace-files/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Parsed document artifact JSON files written by the fn pipeline
    // (Layout, Form, OCR, Genkit parsers).  Authenticated read is required
    // so the browser can call getDownloadURL() and load artifact content
    // for Page / Database creation.  Write is intentionally absent —
    // only the fn Admin SDK may write to this path.
    match /files/{allPaths=**} {
      allow read: if request.auth != null;
    }
  }
}
