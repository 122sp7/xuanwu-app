{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@packages": ["./packages/index.ts"],
      "@infra/client-state": ["./packages/infra/client-state/index.ts"],
      "@infra/http": ["./packages/infra/http/index.ts"],
      "@infra/query": ["./packages/infra/query/index.ts"],
      "@infra/serialization": ["./packages/infra/serialization/index.ts"],
      "@infra/state": ["./packages/infra/state/index.ts"],
      "@infra/trpc": ["./packages/infra/trpc/index.ts"],
      "@infra/uuid": ["./packages/infra/uuid/index.ts"],
      "@infra/zod": ["./packages/infra/zod/index.ts"],
      "@infra/date": ["./packages/infra/date/index.ts"],
      "@integration-ai": ["./packages/integration-ai/index.ts"],
      "@integration-queue": ["./packages/integration-queue/index.ts"],
      "@ui-components": ["./packages/ui-components/index.ts"],
      "@ui-editor": ["./packages/ui-editor/index.ts"],
      "@ui-markdown": ["./packages/ui-markdown/index.tsx"],
      "@ui-visualization": ["./packages/ui-visualization/index.tsx"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "functions"
  ]
}
