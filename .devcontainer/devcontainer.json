{
  "name": "Node 24 & Python uv Dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-24-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/astral-sh/uv/install:1": {} 
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff", // uv 同體系的超快 Linter
        "GitHub.copilot"
      ]
    }
  },
  "mounts": [
    // Node 快取
    "source=${localWorkspaceFolderBasename}-node-modules,target=${containerWorkspaceFolder}/node_modules,type=volume",
    // uv 快取 (這是關鍵，讓 uv install 飛快)
    "source=${localWorkspaceFolderBasename}-uv-cache,target=/home/node/.cache/uv,type=volume"
  ],
  // 自動安裝 Node 套件並同步 Python 環境
  "postCreateCommand": "npm install && uv sync",
  "remoteUser": "node"
}