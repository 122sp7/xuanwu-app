{
  "name": "Node.js 24 Development",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-24-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  },
  // --- 新增：將 node_modules 掛載到獨立的 Volume ---
  "mounts": [
    "source=${localWorkspaceFolderBasename}-node-modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
  ],
  // 這樣即使 Rebuild 容器，npm install 也會飛快完成
  "postCreateCommand": "npm install",
  "remoteUser": "node"
}
