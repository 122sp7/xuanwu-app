%% Xuanwu consolidated system architecture (merged)
%% Merged sources: xuanwu_architecture + project-derivation + system-architecture-overview-combined

flowchart TB
    subgraph Actors[Actors]
        PlatformOwner[Platform Owner]
        OrgAdmin[Organization Admin]
        WorkspaceAdmin[Workspace Admin]
        Member[Member]
        Viewer[Viewer]
    end

    subgraph Runtime[Runtime Split]
        NextRuntime[Next.js Runtime]
        WorkerRuntime[Python Worker py_fn]
        Firestore[(Firestore)]
        Storage[(Cloud Storage)]
        LLM[Genkit and LLM orchestration]
    end

    subgraph Domains[Module Domains]
        WorkspaceDomain[workspace]
        ContentDomain[content]
        KnowledgeGraphDomain[knowledge-graph]
        KnowledgeDomain[knowledge]
        RetrievalDomain[retrieval]
        EventDomain[event]
        IdentityDomain[identity and organization]
    end

    subgraph Layering[MDDD Layer Direction]
        Interfaces[interfaces]
        Application[application]
        Domain[domain]
        Infrastructure[infrastructure]
        PublicApi[api-only cross-module boundary]
        Interfaces --> Application --> Domain
        Infrastructure --> Domain
        Application -. expose .-> PublicApi
    end

    subgraph WorkspaceModel[Multi-workspace Product Model]
        Account[Account]
        WorkspaceA[Workspace A]
        WorkspaceB[Workspace B]
        WorkspaceC[Workspace C]
        CanonicalBoundary[Canonical Workspace Boundary]
        Account --> WorkspaceA
        Account --> WorkspaceB
        Account --> WorkspaceC
        WorkspaceA --> CanonicalBoundary
        WorkspaceB -. same structure .-> CanonicalBoundary
        WorkspaceC -. same structure .-> CanonicalBoundary
    end

    subgraph CanonicalData[Canonical Workspace Data Domains]
        CoreData[Workspace Core]
        KnowledgeData[Knowledge spaces pages blocks]
        StructuredData[Database rows property values]
        AssetData[Files Templates]
        TaxonomyData[Tags]
    end

    PlatformOwner --> NextRuntime
    OrgAdmin --> IdentityDomain
    WorkspaceAdmin --> WorkspaceDomain
    Member --> ContentDomain
    Viewer --> RetrievalDomain

    NextRuntime --> WorkspaceDomain
    NextRuntime --> ContentDomain
    NextRuntime --> KnowledgeDomain
    NextRuntime --> RetrievalDomain
    NextRuntime --> IdentityDomain

    WorkerRuntime --> KnowledgeDomain
    WorkerRuntime --> RetrievalDomain

    ContentDomain --> KnowledgeGraphDomain
    ContentDomain --> KnowledgeDomain
    KnowledgeGraphDomain --> KnowledgeDomain
    KnowledgeDomain --> RetrievalDomain
    RetrievalDomain --> LLM

    WorkspaceDomain --> Firestore
    ContentDomain --> Firestore
    KnowledgeGraphDomain --> Firestore
    KnowledgeDomain --> Firestore
    RetrievalDomain --> Firestore
    EventDomain --> Firestore

    KnowledgeDomain --> Storage
    WorkerRuntime --> Storage

    CanonicalBoundary --> CoreData
    CanonicalBoundary --> KnowledgeData
    CanonicalBoundary --> StructuredData
    CanonicalBoundary --> AssetData
    CanonicalBoundary --> TaxonomyData

    classDef actor fill:#0f172a,stroke:#0f172a,color:#ffffff,stroke-width:1.8px;
    classDef runtime fill:#0f766e,stroke:#115e59,color:#ffffff,stroke-width:1.6px;
    classDef domain fill:#eff6ff,stroke:#2563eb,color:#1e3a8a,stroke-width:1.2px;
    classDef boundary fill:#fff7ed,stroke:#ea580c,color:#9a3412,stroke-width:1.2px;
    classDef data fill:#f8fafc,stroke:#475569,color:#0f172a,stroke-width:1.2px;

    class PlatformOwner,OrgAdmin,WorkspaceAdmin,Member,Viewer actor;
    class NextRuntime,WorkerRuntime,LLM runtime;
    class WorkspaceDomain,ContentDomain,KnowledgeGraphDomain,KnowledgeDomain,RetrievalDomain,EventDomain,IdentityDomain,Interfaces,Application,Domain,Infrastructure,PublicApi domain;
    class Account,WorkspaceA,WorkspaceB,WorkspaceC,CanonicalBoundary boundary;
    class Firestore,Storage,CoreData,KnowledgeData,StructuredData,AssetData,TaxonomyData data;
