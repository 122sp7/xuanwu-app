# ╔═══════════════════════════════════════════════════════════════════════════════╗
# ║  functions-python — Environment Variables                                   ║
# ║  Set these via Firebase Functions config or GCP Secret Manager.             ║
# ╚═══════════════════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────────────────────
# Google Document AI (asia-southeast1)
# ──────────────────────────────────────────────────────────────────────────────
# Required — enables OCR parsing and classification in the RAG ingestion pipeline.
# Without DOCUMENTAI_PROJECT_ID, the pipeline falls back to PassthroughRagParser.
DOCUMENTAI_PROJECT_ID=65970295651
# DOCUMENTAI_LOCATION=asia-southeast1                        # default: asia-southeast1
# DOCUMENTAI_OCR_EXTRACTOR_PROCESSOR_ID=1516a32299c1709e     # default: 1516a32299c1709e
# DOCUMENTAI_OCR_CLASSIFIER_PROCESSOR_ID=17f1013111dec644    # default: 17f1013111dec644
# DOCUMENTAI_OCR_SPLITTER_PROCESSOR_ID=ba69ac6cf5650371      # default: ba69ac6cf5650371

# ──────────────────────────────────────────────────────────────────────────────
# OpenAI — embeddings for RAG ingestion pipeline
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # default: text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536                 # default: 1536
# OPENAI_EMBEDDING_BATCH_SIZE=20                   # default: 20 (max per OpenAI rate limit)
