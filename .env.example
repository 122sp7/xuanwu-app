# ╔═══════════════════════════════════════════════════════════════════════════════╗
# ║  Xuanwu App — Environment Variables                                         ║
# ║  Copy this file to `.env.local` and fill in all required values.            ║
# ╚═══════════════════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────────────────────
# Firebase
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ──────────────────────────────────────────────────────────────────────────────
# OpenAI — embeddings and LLM
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Upstash Redis — key/value store, session cache, wiki document storage
# ──────────────────────────────────────────────────────────────────────────────
# Create at: https://console.upstash.com/redis
# Recommended region: match your Vercel deployment region for lowest latency.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Upstash Vector — semantic similarity search and RAG retrieval
# ──────────────────────────────────────────────────────────────────────────────
# Create at: https://console.upstash.com/vector
#
# ── Provisioning Guide ───────────────────────────────────────────────────────
#
# Region (choose one close to your deployment):
#   • us-east-1  — Washington, D.C., USA (East)                  [lad1]
#   • eu-west-1  — Dublin, Ireland (West)                        [dub1]
#   • us-central1 — GCP Iowa, USA                                [us-central1]
#
# Index Type:
#   • DENSE   — standard float vector embeddings (default, recommended)
#   • SPARSE  — keyword/BM25-style sparse vectors
#   • HYBRID  — combines dense + sparse for maximum recall
#
# Dense Embedding Model (select based on your embedding provider):
#   • None                — use external embeddings (e.g. OpenAI text-embedding-3-small)
#   • BGE_SMALL_EN_V1_5   — 384 dims, fastest, English only
#   • BGE_BASE_EN_V1_5    — 768 dims, balanced
#   • BGE_LARGE_EN_V1_5   — 1024 dims, highest quality, English only
#   • BGE_M3              — 1024 dims, multilingual (recommended for CJK content)
#
#   NOTE: This project uses OpenAI text-embedding-3-small (1536 dims) by default.
#         Select "None" for the Dense Embedding Model and ensure the vector
#         dimension is set to 1536 when creating the index.
#
# Similarity Function:
#   • COSINE        — default, works well with normalised embeddings (recommended)
#   • DOT_PRODUCT   — faster, requires normalised vectors
#   • EUCLIDEAN     — L2 distance
#
# Sparse Embedding Model (only for SPARSE / HYBRID index types):
#   • None   — no sparse embeddings
#   • BM25   — classic keyword matching
#   • BGE_M3 — multilingual sparse embeddings
#
# ── Recommended Configuration ────────────────────────────────────────────────
#   Region:               us-east-1 (or match Vercel region)
#   Index Type:           DENSE
#   Dense Embedding Model: None (external — OpenAI text-embedding-3-small)
#   Dimensions:           1536
#   Similarity Function:  COSINE
#   NOTE: Changing the embedding model or dimensions after index creation
#         requires recreating the Upstash Vector index — this is NOT a
#         runtime-only change.
#
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Upstash Search — AI-powered full-text + semantic search
# ──────────────────────────────────────────────────────────────────────────────
# Create at: https://console.upstash.com/search
# Combines full-text and semantic search over named indexes.
# Built on top of Upstash Vector — handles embedding and retrieval automatically.
UPSTASH_SEARCH_REST_URL=
UPSTASH_SEARCH_REST_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Upstash QStash — durable message queue and scheduler
# ──────────────────────────────────────────────────────────────────────────────
# Create at: https://console.upstash.com/qstash
# QSTASH_TOKEN is used by QStash publisher, Workflow SDK, and schedule management.
# Signing keys are used to verify incoming QStash webhook payloads.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Upstash Box — sandboxed AI coding agent runtime (optional)
# ──────────────────────────────────────────────────────────────────────────────
# Create at: https://console.upstash.com/box
# Only needed if using the agentic sandbox feature.
UPSTASH_BOX_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
