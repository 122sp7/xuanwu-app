%% Xuanwu consolidated RAG E2E (merged)
%% Merged sources: rag-enterprise-e2e + api-data-flow + core-logic

flowchart LR
    User[User] --> Upload[Upload Document]
    User --> Query[Ask Question]

    subgraph NextRuntime[Next.js Runtime]
        direction TB
        Upload --> ValidateScope[Validate auth tenant workspace]
        ValidateScope --> CreateDoc[Create documentId and metadata]
        CreateDoc --> WriteMeta[Write Firestore documents status uploaded]
        Query --> QueryGate[Permission readiness cache gate]
        QueryGate --> BuildPrompt[Context assembly and prompt build]
        BuildPrompt --> StreamAnswer[Stream answer with citations]
        StreamAnswer --> FeedbackAction[SubmitRagQueryFeedbackUseCase]
    end

    subgraph DataPlane[Data Plane]
        direction TB
        Storage[(Storage raw and derived)]
        Documents[(Firestore documents)]
        Chunks[(Firestore chunks with embedding)]
        QueryCache[(Query cache optional)]
        FeedbackStore[(Firestore ragQueryFeedback)]
    end

    subgraph WorkerPlane[Python Worker]
        direction TB
        Trigger[Trigger on uploaded document]
        Parse[Parse and normalize]
        Taxonomy[Document taxonomy]
        Chunking[Chunk and metadata]
        Embedding[Embedding generation]
        Persist[Upsert chunks documentId_chunkIndex]
        MarkReady[Mark document ready or failed]
    end

    subgraph Retrieval[Retrieval and LLM]
        direction TB
        QueryEmbedding[Query embedding]
        VectorSearch[Vector search Top-K and filters]
        Hybrid[Optional hybrid retrieval and rerank]
        LLM[Genkit flow and LLM answer]
        NoContext[Fallback when no context]
    end

    WriteMeta --> Documents
    CreateDoc --> Storage
    Documents --> Trigger
    Storage --> Trigger

    Trigger --> Parse --> Taxonomy --> Chunking --> Embedding --> Persist --> MarkReady
    Persist --> Chunks
    MarkReady --> Documents

    QueryGate --> Documents
    QueryGate --> Chunks
    QueryGate --> QueryCache

    BuildPrompt --> QueryEmbedding --> VectorSearch
    VectorSearch --> Hybrid
    VectorSearch --> NoContext
    Hybrid --> LLM
    LLM --> StreamAnswer
    FeedbackAction --> FeedbackStore

    classDef actor fill:#0f172a,stroke:#0f172a,color:#ffffff,stroke-width:1.8px;
    classDef runtime fill:#0f766e,stroke:#115e59,color:#ffffff,stroke-width:1.6px;
    classDef worker fill:#fff7ed,stroke:#ea580c,color:#9a3412,stroke-width:1.2px;
    classDef data fill:#f8fafc,stroke:#475569,color:#0f172a,stroke-width:1.2px;
    classDef retrieval fill:#eef2ff,stroke:#4f46e5,color:#312e81,stroke-width:1.2px;
    classDef feedback fill:#f0fdf4,stroke:#16a34a,color:#14532d,stroke-width:1.2px;

    class User actor;
    class Upload,Query,ValidateScope,CreateDoc,WriteMeta,QueryGate,BuildPrompt,StreamAnswer,FeedbackAction runtime;
    class Trigger,Parse,Taxonomy,Chunking,Embedding,Persist,MarkReady worker;
    class Storage,Documents,Chunks,QueryCache data;
    class QueryEmbedding,VectorSearch,Hybrid,LLM,NoContext retrieval;
    class FeedbackStore feedback;
