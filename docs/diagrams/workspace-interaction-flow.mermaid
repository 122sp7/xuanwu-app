%% Xuanwu consolidated workspace map (merged)
%% Merged sources: workspace-interaction-flow + system-multi-workspace-hierarchy + nextjs-app-router-structure + firestore-collection-path-structure

flowchart TB
    subgraph AccountHierarchy[Account and Workspace Hierarchy]
        Account[Account]
        WA[Workspace A]
        WB[Workspace B]
        WC[Workspace C]
        Account --> WA
        Account --> WB
        Account --> WC
    end

    subgraph Router[Next.js App Router Slices]
        PublicRoot[/]
        Dashboard[/dashboard]
        WorkspaceHub[/workspace]
        WorkspaceDetail[/workspace/:workspaceId]
        AiChat[/ai-chat]
        WikiBeta[/wiki-beta/*]
        Organization[/organization/*]
        Settings[/settings/*]
    end

    subgraph CoreInteraction[Workspace Interaction Flow]
        Start[Open App]
        Auth{Authenticated}
        SelectWorkspace{Select workspace}
        Membership{Membership valid}
        Shell[Bootstrap shell]
        Intent{User intent}
        PageFlow[Page editing flow]
        DatabaseFlow[Database row flow]
        FileFlow[File upload and linking]
        SearchFlow[Workspace search]
        AdminFlow[Members and settings]

        Start --> Auth --> SelectWorkspace --> Membership
        Membership -->|yes| Shell --> Intent
        Membership -->|no| SelectWorkspace
        Intent --> PageFlow
        Intent --> DatabaseFlow
        Intent --> FileFlow
        Intent --> SearchFlow
        Intent --> AdminFlow
    end

    subgraph FirestoreCollections[Firestore Collection Paths]
        Accounts[accounts/{accountId}]
        Organizations[organizations/{organizationId}]
        Workspaces[workspaces/{workspaceId}]
        WorkspaceTasks[workspaceTasks/{taskId}]
        WorkspaceIssues[workspaceIssues/{issueId}]
        Notifications[notifications/{notificationId}]
        AuditLogs[auditLogs/{logId}]
        TokenSignals[tokenRefreshSignals/{accountId}]
        Finance[finance/{workspaceId}]
        FileDocuments[fileDocuments/{fileId}]
    end

    WA --> WorkspaceDetail
    WorkspaceDetail --> Shell

    Shell --> Workspaces
    Shell --> WorkspaceTasks
    Shell --> WorkspaceIssues
    Shell --> Notifications
    Shell --> AuditLogs
    Shell --> FileDocuments

    Auth -. token refresh .-> TokenSignals
    Organization --> Organizations
    Settings --> Accounts
    Dashboard --> Finance

    classDef root fill:#0f172a,stroke:#0f172a,color:#ffffff,stroke-width:1.8px;
    classDef route fill:#0f766e,stroke:#115e59,color:#ffffff,stroke-width:1.4px;
    classDef flow fill:#eff6ff,stroke:#2563eb,color:#1e3a8a,stroke-width:1.2px;
    classDef data fill:#f8fafc,stroke:#475569,color:#0f172a,stroke-width:1.2px;

    class Account,WA,WB,WC root;
    class PublicRoot,Dashboard,WorkspaceHub,WorkspaceDetail,AiChat,WikiBeta,Organization,Settings route;
    class Start,Auth,SelectWorkspace,Membership,Shell,Intent,PageFlow,DatabaseFlow,FileFlow,SearchFlow,AdminFlow flow;
    class Accounts,Organizations,Workspaces,WorkspaceTasks,WorkspaceIssues,Notifications,AuditLogs,TokenSignals,Finance,FileDocuments data;